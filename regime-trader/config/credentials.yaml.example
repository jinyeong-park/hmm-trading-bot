# ============================================================
# credentials.yaml.example
# Copy to credentials.yaml and fill in real values.
# credentials.yaml is git-ignored — never commit secrets.
# ============================================================

alpaca:
  api_key: "YOUR_ALPACA_API_KEY"
  secret_key: "YOUR_ALPACA_SECRET_KEY"
  paper: true

alerts:
  smtp:
    host: "smtp.gmail.com"
    port: 587
    username: "you@gmail.com"
    password: "your_app_password"
    from_addr: "you@gmail.com"
    to_addrs:
      - "you@gmail.com"
  webhook_url: ""           # Slack / Discord / PagerDuty webhook URL (optional)
